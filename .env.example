# ─────────────────────────────────────────────
# Ebb — Environment Variables
# Copy to .env and fill in values before running
# Never commit .env to version control
# ─────────────────────────────────────────────

# Cryptography
# 32-char random string — generated once per install, never changes
# Generate: node -e "console.log(require('crypto').randomBytes(24).toString('base64'))"
DB_ENCRYPTION_SALT=change-me-generate-a-random-32-char-string

# Google Calendar OAuth 2.0
# Create at: https://console.cloud.google.com → APIs & Services → Credentials
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:3001/auth/google/callback

# Oura OAuth
# Create at: https://cloud.ouraring.com/oauth/applications
OURA_CLIENT_ID=
OURA_CLIENT_SECRET=
OURA_REDIRECT_URI=http://localhost:3001/auth/oura/callback

# Server
PORT=3001
NODE_ENV=development
